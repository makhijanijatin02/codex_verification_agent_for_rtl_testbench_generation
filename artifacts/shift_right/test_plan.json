    {
      "description": "No reset input exists; after power-up apply a stable vector (e.g., in_symbols=[0,1,...,9], shift=0, fill=0) and confirm out mirrors the input immediately and out_valid is 1 without any reset sequencing.",
      "cycles": 1
    }
  ],
  "normal_tests": [
