  "random_tests": {
    "num_vectors": 300,
    "description": "Generate random 50-bit inputs, random fill symbols, and random 3-bit shifts; expect out_valid=1 for shift<=4 with symbol-aligned barrel shift + replicated fill, else out_valid=0. Include bursts of consecutive vectors to catch combinational glitches."
  },
  "key_discriminators": [
    "out_valid must be 1 only when shift is 0\u20134; any higher value forces it low regardless of fill or data.",
    "Vacated most-significant symbols must all take the identical 5-bit fill value; no per-position fill or zeroing.",
    "No wraparound: symbols shifted beyond index 0 disappear rather than reappear at MS slots.",
    "Bit slicing happens in 5-bit chunks; off-by-one bit shifts will immediately corrupt boundary tests.",
    "Combinational behavior only: output must respond to input changes within the same cycle without requiring reset or clocking."
  ]
}